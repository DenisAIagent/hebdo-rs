PORT=3005

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key

# Dropbox
DROPBOX_APP_KEY=your-app-key
DROPBOX_APP_SECRET=your-app-secret
DROPBOX_REFRESH_TOKEN=your-refresh-token
DROPBOX_ROOT_FOLDER=/Hebdo Delivery

# Email notifications (Resend — https://resend.com)
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=RS Hebdo <onboarding@resend.dev>
NOTIFY_EMAIL_ALMA=alma@rollingstone.fr
NOTIFY_EMAIL_DENIS=denis@rollingstone.fr

# Setup security token (required for /api/setup/configure)
SETUP_SECRET_TOKEN=generate-a-random-string-here

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
